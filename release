#!/usr/bin/env bash
# release — guided release lifecycle for Lake
#
#   ./release start <name>     Branch feature/<name> off main
#   ./release bump <level>     Bump LAKE_SETUP_VERSION (patch|minor|major|X.Y.Z), commit
#   ./release pr               Push current branch + open PR into main
#   ./release tag              Tag main with its current version (after the PR merges); prunes merged feature branches
#   ./release status           Show current branch, local version, latest GitHub release
#
# Every destructive step prints what it will do and asks before running.
# Branch rule (see .note): features branch off main and PR straight into main.
set -euo pipefail

REPO="wednesdaysmoonlab/lake"
LAKEUP="lakeup"

# ── helpers ──────────────────────────────────────────────────────────────────
_say()  { printf '\e[38;5;117m✦\e[0m %s\n' "$*"; }
_warn() { printf '\e[1;33m⚠ %s\e[0m\n' "$*" >&2; }
_err()  { printf '\e[1;31m✖ %s\e[0m\n' "$*" >&2; exit 1; }
_ask()  {
  local _ans
  printf '\e[1;31m❓ %s\e[0m ' "$1" >&2
  read -r _ans </dev/tty
  echo "${_ans:-${2:-}}"
}
# _confirm "Question?"  → returns 0 on yes (default Y), 1 on no
_confirm() {
  local _ans
  printf '\e[1;31m❓ %s [Y/n]:\e[0m ' "$1" >&2
  read -r _ans </dev/tty
  [[ "${_ans:-Y}" =~ ^[Yy]$ ]]
}

_require_clean() {
  if ! git diff --quiet || ! git diff --cached --quiet; then
    _err "Uncommitted changes detected. Commit or stash them first."
  fi
}

_local_version() {
  grep -E '^LAKE_SETUP_VERSION=' "$LAKEUP" | head -1 | cut -d'"' -f2
}

_latest_release() {
  local json
  json=$(curl -fsSL "https://api.github.com/repos/${REPO}/releases/latest" 2>/dev/null) || true
  if [[ -z "$json" ]] || echo "$json" | grep -q '"message": "Not Found"'; then
    echo ""
  else
    echo "$json" | grep '"tag_name"' | head -1 | sed 's/.*"tag_name": *"v\{0,1\}\([^"]*\)".*/\1/'
  fi
}

# Pretty-print a possibly-empty version string for display
_fmt_release() { [[ -n "$1" ]] && echo "v$1" || echo "(none)"; }

# ── start <name> ─────────────────────────────────────────────────────────────
cmd_start() {
  local name="${1:-}"
  [[ -n "$name" ]] || _err "Usage: ./release start <name>"
  name="${name#feature/}"   # tolerate an explicit feature/ prefix
  local branch="feature/${name}"

  _require_clean
  git rev-parse --verify "$branch" &>/dev/null && _err "Branch ${branch} already exists."

  _say "Branching ${branch} off main."
  git checkout main
  git pull origin main
  git checkout -b "$branch"
  _say "On ${branch}. Start coding, then: ./release pr"
}

# ── pr ───────────────────────────────────────────────────────────────────────
cmd_pr() {
  local branch
  branch=$(git rev-parse --abbrev-ref HEAD)
  [[ "$branch" == feature/* ]] || _err "Not on a feature/* branch (on '$branch'). Use ./release start <name> first."
  command -v gh &>/dev/null || _err "GitHub CLI 'gh' not found. Install it: https://cli.github.com"

  if [[ -n "$(git status --porcelain)" ]]; then
    _warn "You have uncommitted changes — commit them before opening a PR."
  fi

  _confirm "Push ${branch} and open a PR into main?" || { _say "Aborted."; exit 0; }
  git push -u origin "$branch"
  gh pr create --base main --head "$branch" --fill
  _say "PR opened into main. Review & squash-merge it on GitHub, then: ./release tag"
}

# ── bump <patch|minor|major|X.Y.Z> ───────────────────────────────────────────
cmd_bump() {
  local level="${1:-}"
  [[ -n "$level" ]] || _err "Usage: ./release bump <patch|minor|major|X.Y.Z>"

  local branch
  branch=$(git rev-parse --abbrev-ref HEAD)
  if [[ "$branch" == "main" ]]; then
    _warn "You are on main (protected). Bump on a feature branch instead — see ./release start."
    _confirm "Bump on main anyway?" || { _say "Aborted."; exit 0; }
  fi
  _require_clean

  local cur new
  cur=$(_local_version)
  [[ -n "$cur" ]] || _err "Could not read LAKE_SETUP_VERSION from ${LAKEUP}."

  if [[ "$level" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
    new="$level"
  else
    local major minor patch
    IFS='.' read -r major minor patch <<<"$cur"
    case "$level" in
      patch) new="${major}.${minor}.$((patch + 1))" ;;
      minor) new="${major}.$((minor + 1)).0" ;;
      major) new="$((major + 1)).0.0" ;;
      *)     _err "Unknown level '${level}'. Use patch|minor|major|X.Y.Z." ;;
    esac
  fi

  _confirm "Bump version ${cur} → ${new}?" || { _say "Aborted."; exit 0; }

  # Portable in-place edit (BSD vs GNU sed)
  if sed --version &>/dev/null; then
    sed -i "s/^LAKE_SETUP_VERSION=\"${cur}\"/LAKE_SETUP_VERSION=\"${new}\"/" "$LAKEUP"
  else
    sed -i '' "s/^LAKE_SETUP_VERSION=\"${cur}\"/LAKE_SETUP_VERSION=\"${new}\"/" "$LAKEUP"
  fi
  [[ "$(_local_version)" == "$new" ]] || _err "Failed to update version in ${LAKEUP}."

  git commit -am "chore: bump version to ${new}"
  _say "Bumped to ${new} and committed. When ready: ./release pr"
}

# Delete local feature/* branches whose changes already landed on main, plus the
# matching origin ref. Handles squash-merges (the default here): `git branch -d`
# can't see a squashed branch as merged, so we ask `git cherry` — if every commit
# is prefixed '-', its diff is already in main and the branch is safe to force-delete.
_cleanup_merged_branches() {
  local current branch line unmerged
  current=$(git rev-parse --abbrev-ref HEAD)
  git fetch --prune origin &>/dev/null || true

  while IFS= read -r branch; do
    [[ -n "$branch" ]] || continue
    [[ "$branch" == "$current" ]] && continue   # never delete the branch we're on

    # git cherry prints one line per commit: '-' = already in main, '+' = not yet.
    unmerged=0
    while IFS= read -r line; do
      [[ "$line" == +* ]] && { unmerged=1; break; }
    done < <(git cherry main "$branch" 2>/dev/null)
    [[ "$unmerged" -eq 1 ]] && continue          # still has unmerged work — leave it

    _say "Cleaning up merged branch: ${branch}"
    git branch -D "$branch" &>/dev/null || true
    if git ls-remote --exit-code --heads origin "$branch" &>/dev/null; then
      git push origin --delete "$branch" &>/dev/null \
        && _say "  deleted origin/${branch}" || true
    fi
  done < <(git for-each-ref --format='%(refname:short)' refs/heads/feature)
}

_assert_tag_free() {
  local tag="$1"
  if git rev-parse "$tag" &>/dev/null; then
    _err "Tag ${tag} already exists locally. Run ./release bump to pick a new version."
  fi
  if git ls-remote --tags origin "$tag" 2>/dev/null | grep -q .; then
    _err "Tag ${tag} already exists on origin. Run ./release bump to pick a new version."
  fi
}

# Tag the current main HEAD (must already hold the release version) and push.
_tag_and_push() {
  local tag="$1"
  _assert_tag_free "$tag"
  _confirm "Tag main as ${tag} and push (triggers the release build)?" || { _say "Aborted — nothing tagged."; exit 0; }
  git tag "$tag"
  git push origin "$tag"
  _say "Done! Release workflow will trigger at:"
  _say "  https://github.com/${REPO}/releases/tag/${tag}"
}

# ── tag ──────────────────────────────────────────────────────────────────────
# Tag main with its current version. Use after the feature PR is merged on GitHub.
cmd_tag() {
  _require_clean
  git checkout main
  git pull origin main
  local version tag
  version=$(_local_version)
  if ! [[ "$version" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
    _err "main has invalid version '${version}' in ${LAKEUP}."
  fi
  tag="v${version}"
  _say "Tagging main : ${tag}"
  _say "Latest GitHub release : $(_fmt_release "$(_latest_release)")"
  _tag_and_push "$tag"
  _cleanup_merged_branches
}

# ── status ───────────────────────────────────────────────────────────────────
cmd_status() {
  local branch latest
  branch=$(git rev-parse --abbrev-ref HEAD)
  latest=$(_latest_release)
  _say "Branch                : ${branch}"
  _say "Version in lakeup     : v$(_local_version)"
  _say "Latest GitHub release : $(_fmt_release "$latest")"
}

# ── help ─────────────────────────────────────────────────────────────────────
cmd_help() {
  cat <<'EOF'
release — guided release lifecycle for Lake

  ./release start <name>     Branch feature/<name> off main
  ./release bump <level>     Bump version (patch|minor|major|X.Y.Z), commit on the feature branch
  ./release pr               Push current branch + open a PR into main
  ./release tag              Tag main with its current version (after the PR merges); prunes merged feature branches
  ./release status           Show branch, local version, latest GitHub release

Typical flow:
  ./release start octane-tuning   # branch off main, develop, commit
  ./release bump minor            # bump version on the feature branch
  ./release pr                    # PR → main, review & squash-merge on GitHub
  ./release tag                   # tag merged main → release built

main is protected (changes go through a PR), so releases never push to main directly.
Run 'tag' once the PR is squash-merged on GitHub.
EOF
}

# ── dispatch ─────────────────────────────────────────────────────────────────
case "${1:-help}" in
  start)  shift; cmd_start "$@" ;;
  bump)   shift; cmd_bump "$@" ;;
  pr)     shift; cmd_pr "$@" ;;
  tag)    shift; cmd_tag "$@" ;;
  status) shift; cmd_status "$@" ;;
  help|-h|--help) cmd_help ;;
  *) _err "Unknown command '${1}'. Run ./release help." ;;
esac
