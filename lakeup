# INSTALL / ENSURE DEPENDENCIES
# ----------------------------

if [[ ! -d "vendor" ]]; then
  _say "Running composer install..."
  "$FRANKEN_BIN" php-cli "$COMPOSER_BIN" install --no-interaction
fi

