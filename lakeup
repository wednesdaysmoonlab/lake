#!/usr/bin/env bash
set -euo pipefail

LAKE_SETUP_VERSION="0.7.2"

_lake_logo() {
  local sky=$'\e[38;5;117m' db=$'\e[38;5;27m' ls=$'\e[38;5;153m' r=$'\e[0m'
  local line out i char
  while IFS= read -r line; do
    out=""
    for (( i=0; i<${#line}; i++ )); do
      char="${line:$i:1}"
      case "$char" in
        _)  out+="${ls}_" ;;
        /)  out+="${sky}/" ;;
        \\) out+="${sky}\\" ;;
        *)  out+="${r}${char}" ;;
      esac
    done
    printf '%s%s\n' "$out" "$r"
  done << 'LOGO'
     _/\/\____________________/\/\___________________
    _/\/\________/\/\/\______/\/\__/\/\____/\/\/\___
   _/\/\____________/\/\____/\/\/\/\____/\/\/\/\/\_
  _/\/\________/\/\/\/\____/\/\/\/\____/\/\_______
 _/\/\/\/\/\__/\/\/\/\/\__/\/\__/\/\____/\/\/\/\_
________________________________________________
LOGO
}
_lake_logo
unset -f _lake_logo

_say() { printf '\e[38;5;117m✦\e[0m %s\n' "$*"; }
echo ""
_say "lakeup v${LAKE_SETUP_VERSION}"
echo ""
_confirm() {
  local _ans
  printf '\e[1;31m❓ %s [Y/n]:\e[0m ' "$*" >&2
  read -r _ans </dev/tty
  _ans="${_ans:-Y}"
  [[ "$_ans" =~ ^[Yy]$ ]]
}
_confirm_no() {  # like _confirm, but defaults to NO (safe for curl | bash / no TTY)
  local _ans
  printf '\e[1;31m❓ %s [y/N]:\e[0m ' "$*" >&2
  read -r _ans </dev/tty 2>/dev/null || _ans=""
  _ans="${_ans:-N}"
  [[ "$_ans" =~ ^[Yy]$ ]]
}
_ask() {  # _ask "Question [default]:" "default_value"
  local _ans
  printf '\e[1;31m❓ %s\e[0m ' "$1" >&2
  read -r _ans </dev/tty
  echo "${_ans:-${2:-}}"
}
_seed_boost_php_path() {
  # If Laravel Boost is installed, point its MCP php binary at the Lake shim.
  # Boost resolves every agent's MCP `command` from env('BOOST_PHP_EXECUTABLE_PATH')
  # (config/boost.php → executable_paths.php), so seeding this single .env line wires
  # ALL coding agents (Claude Code, Cursor, Codex, Copilot, Junie, Kiro, Zed, ...) to
  # .lake/php at once — for the user's own `boost:install` now and every future run.
  # Absolute path is used on purpose: Junie and Amp force absolute MCP command paths.
  # NOTE: keep in sync with tests/helpers/seed_boost_php_path
  [[ -d "vendor/laravel/boost" ]] || return 0
  [[ -f ".env" ]] || return 0

  local target line _tmp _l
  target="$(pwd)/.lake/php"
  line="BOOST_PHP_EXECUTABLE_PATH=\"${target}\""

  if grep -q '^BOOST_PHP_EXECUTABLE_PATH=' .env 2>/dev/null; then
    _tmp="$(mktemp)"
    while IFS= read -r _l || [[ -n "$_l" ]]; do
      if [[ "$_l" == BOOST_PHP_EXECUTABLE_PATH=* ]]; then
        printf '%s\n' "$line"
      else
        printf '%s\n' "$_l"
      fi
    done < .env > "$_tmp"
    mv "$_tmp" .env
  else
    # Ensure a trailing newline before appending, so we never join onto a previous line.
    [[ -n "$(tail -c1 .env 2>/dev/null)" ]] && printf '\n' >> .env
    printf '%s\n' "$line" >> .env
  fi

  _say "Boost detected: set BOOST_PHP_EXECUTABLE_PATH → .lake/php in .env (wires all MCP agents)."
}
_patch_agent_mcp_php() {
  # MCP installers (laravel/boost's `boost:install`, etc.) write each AI agent's
  # config with `command: php`. A Lake project has no system PHP, so rewrite
  # every known agent config to the absolute .lake/php shim — the exact value
  # Boost itself writes once BOOST_PHP_EXECUTABLE_PATH is set. Running it here
  # repairs configs left over from a `boost:install` that ran BEFORE the .env
  # seed (only .mcp.json was patched historically, so Codex/OpenCode/Zed/Amp/...
  # were left pointing at a non-existent `php`). Idempotent and safe on every
  # bootstrap: only a bare `php` command is rewritten. Covers JSON (both the
  # "command": "php" string form and OpenCode's "command": [ "php", ... ] array
  # form) and Codex's TOML (command = "php").
  # NOTE: keep in sync with tests/helpers/patch_agent_mcp
  local target abs_esc f changed=() _OS
  _OS="$(uname -s)"
  target="$(pwd)/.lake/php"
  # Escape sed replacement metacharacters (#, &, \) in the path.
  abs_esc="$(printf '%s' "$target" | sed 's/[#&\]/\\&/g')"

  # Every agent MCP config file Boost can write (see laravel/boost Install/Agents).
  local files=( .mcp.json opencode.json .codex/config.toml .amp/settings.json \
    .zed/settings.json .factory/mcp.json .cursor/mcp.json .vscode/mcp.json \
    .junie/mcp/mcp.json .kiro/settings/mcp.json )

  for f in "${files[@]}"; do
    [[ -f "$f" ]] || continue
    # Skip files that don't reference a bare `php` command (idempotent no-op).
    grep -qE '"command"[[:space:]]*:[[:space:]]*"php"|command[[:space:]]*=[[:space:]]*"php"|^[[:space:]]*"php"[[:space:]]*,?[[:space:]]*$' "$f" 2>/dev/null || continue
    if [[ "$_OS" == "Darwin" ]]; then
      sed -i '' -E \
        -e "s#(\"command\"[[:space:]]*:[[:space:]]*)\"php\"#\1\"$abs_esc\"#g" \
        -e "s#(command[[:space:]]*=[[:space:]]*)\"php\"#\1\"$abs_esc\"#g" \
        -e "s#^([[:space:]]*)\"php\"([[:space:]]*,?)[[:space:]]*\$#\1\"$abs_esc\"\2#g" \
        "$f"
    else
      sed -i -E \
        -e "s#(\"command\"[[:space:]]*:[[:space:]]*)\"php\"#\1\"$abs_esc\"#g" \
        -e "s#(command[[:space:]]*=[[:space:]]*)\"php\"#\1\"$abs_esc\"#g" \
        -e "s#^([[:space:]]*)\"php\"([[:space:]]*,?)[[:space:]]*\$#\1\"$abs_esc\"\2#g" \
        "$f"
    fi
    changed+=("$f")
  done

  if (( ${#changed[@]} )); then
    _say "Patched AI agent MCP config(s) → .lake/php: ${changed[*]}"
  fi
}
_install_lake_skill() {
  # Install the "lake" agent skill so AI coding agents use the .lake/ shims
  # instead of bare php/composer (which fail — there is no host runtime).
  # One SKILL.md (identical format/content) covers all three target agents:
  #   .claude/skills/lake/  → Claude Code + OpenCode
  #   .agents/skills/lake/  → Codex + OpenCode
  # Lake-owned dirs, so always overwrite. Non-interactive, idempotent.
  # NOTE: keep in sync with tests/helpers/install_lake_skill
  local _dir
  for _dir in .claude/skills/lake .agents/skills/lake; do
    mkdir -p "$_dir"
    cat > "$_dir/SKILL.md" <<'SKILLEOF'
---
name: lake
description: How to run commands in a Lake-provisioned Laravel project. Use
  whenever running PHP, Artisan, Composer, tests, or the dev server in a repo
  that contains a .lake/ directory.
---

# Working in a Lake project

This project is bootstrapped by **Lake** — there is NO host PHP, Composer, or
Docker. All tooling lives in `.lake/` shims. NEVER call bare `php`, `composer`,
`artisan`, or `php artisan` — they will fail.

## Commands — always use the shims
- PHP:        `.lake/php <args>`        (NOT `php`)
- Artisan:    `.lake/php artisan <cmd>` (NOT `php artisan`)
- Composer:   `.lake/composer <cmd>`    (NOT `composer`)
- Dev server: `.lake/composer run dev`  (FrankenPHP + queue + logs + Vite)
- Tests:      `.lake/composer run test`

## Notes
- SQLite is the default DB (`database/database.sqlite`).
- Re-bootstrap/reset is `./lakeup` (and `./lakeup purge` / `clean`).
- Don't suggest installing PHP/Composer on the host — Lake is self-contained.
SKILLEOF
  done
  _say "Installed the 'lake' AI skill → .claude/skills/lake, .agents/skills/lake."
}
_version_gt() {
  # Returns 0 (true) if $1 > $2  (semver X.Y.Z)
  local IFS='.'
  local -a a b
  read -ra a <<< "$1"
  read -ra b <<< "$2"
  for i in 0 1 2; do
    local av="${a[$i]:-0}" bv="${b[$i]:-0}"
    (( av > bv )) && return 0
    (( av < bv )) && return 1
  done
  return 1  # equal
}

# ======================================
#  lakeup
#  Laravel + FrankenPHP bootstrap
#  No Docker. No local PHP required.
# ======================================

# ----------------------------
# --help FLAG
# ----------------------------

if [[ "${1:-}" == "help" || "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
  cat <<HELPEOF
lakeup v${LAKE_SETUP_VERSION}

Usage:
  ./lakeup [COMMAND]

Commands:
  purge         Remove everything in this directory except lakeup, .claude, .git, .gitignore, CLAUDE.md, and README.md
  clean         Remove Laravel app files only; keep .lake/ (FrankenPHP, Composer, installer)
  update        Check for a newer version of lakeup and update in-place
  skill         Install the Lake AI skill for Claude Code, Codex, and OpenCode
  version       Show lakeup and Laravel versions
  help          Show this help message

Environment overrides:
  FRANKEN_VERSION=1.11.2   Pin a specific FrankenPHP version (skips interactive prompt)
  LAKE_PORT=9000            Skip the port prompt and use this port

Example:
  FRANKEN_VERSION=1.11.2 LAKE_PORT=9000 ./lakeup
HELPEOF
  exit 0
fi

# ----------------------------
# purge COMMAND
# ----------------------------

if [[ "${1:-}" == "purge" ]]; then
  if [[ -n "${BASH_SOURCE[0]:-}" && -f "${BASH_SOURCE[0]}" ]]; then
    SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    SCRIPT_NAME="$(basename "${BASH_SOURCE[0]}")"
  else
    SCRIPT_DIR="$(pwd)"
    SCRIPT_NAME=""
  fi
  _say "Purging $SCRIPT_DIR (keeping $SCRIPT_NAME)..."
  find "$SCRIPT_DIR" -mindepth 1 -maxdepth 1 \
    ! -name "$SCRIPT_NAME" \
    ! -name ".claude" \
    ! -name ".git" \
    ! -name ".gitignore" \
    ! -name "CLAUDE.md" \
    ! -name "README.md" \
    -exec rm -rf {} +
  _say "Done."
  exit 0
fi

# ----------------------------
# clean COMMAND
# ----------------------------

if [[ "${1:-}" == "clean" ]]; then
  if [[ -n "${BASH_SOURCE[0]:-}" && -f "${BASH_SOURCE[0]}" ]]; then
    SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    SCRIPT_NAME="$(basename "${BASH_SOURCE[0]}")"
  else
    SCRIPT_DIR="$(pwd)"
    SCRIPT_NAME=""
  fi
  _say "Cleaning Laravel app files (keeping .lake/, $SCRIPT_NAME)..."
  find "$SCRIPT_DIR" -mindepth 1 -maxdepth 1 \
    ! -name "$SCRIPT_NAME" \
    ! -name ".claude" \
    ! -name ".git" \
    ! -name ".gitignore" \
    ! -name "CLAUDE.md" \
    ! -name "README.md" \
    ! -name ".lake" \
    -exec rm -rf {} +
  _say "Done. Run ./lakeup to reinstall Laravel."
  exit 0
fi

# ----------------------------
# update COMMAND
# ----------------------------

if [[ "${1:-}" == "update" ]]; then
  # Must be run as a file, not piped
  if [[ -z "${BASH_SOURCE[0]:-}" || ! -f "${BASH_SOURCE[0]}" ]]; then
    _say "Cannot update: run lakeup as a file, not via curl | bash."
    exit 1
  fi
  SELF="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/$(basename "${BASH_SOURCE[0]}")"

  _say "Checking for updates..."

  RELEASE_JSON=$(curl -fsSL "https://api.github.com/repos/wednesdaysmoonlab/lake/releases/latest" 2>/dev/null) || {
    _say "Could not reach GitHub API. Check your internet connection."
    exit 1
  }

  LATEST_TAG=$(echo "$RELEASE_JSON" | grep '"tag_name"' | head -1 | sed 's/[^"]*"tag_name"[^"]*"\([^"]*\)".*/\1/')
  LATEST_VERSION="${LATEST_TAG#v}"   # strip leading 'v' if present

  if [[ -z "$LATEST_VERSION" ]]; then
    _say "No releases found. Check https://github.com/wednesdaysmoonlab/lake/releases"
    exit 1
  fi

  _say "Current version : v${LAKE_SETUP_VERSION}"
  _say "Latest version  : v${LATEST_VERSION}"

  if [[ "$LAKE_SETUP_VERSION" == "$LATEST_VERSION" ]]; then
    _say "Already up to date."
    exit 0
  fi

  if ! _version_gt "$LATEST_VERSION" "$LAKE_SETUP_VERSION"; then
    _say "You are running a newer version than the latest release."
    exit 0
  fi

  if _confirm "Update lakeup v${LAKE_SETUP_VERSION} → v${LATEST_VERSION}?"; then
    TMP_FILE="$(mktemp)"
    DOWNLOAD_URL="https://github.com/wednesdaysmoonlab/lake/releases/download/${LATEST_TAG}/lakeup"
    _say "Downloading v${LATEST_VERSION}..."
    if ! curl -fsSL "$DOWNLOAD_URL" -o "$TMP_FILE"; then
      rm -f "$TMP_FILE"
      _say "Download failed."
      exit 1
    fi
    chmod +x "$TMP_FILE"
    mv "$TMP_FILE" "$SELF"
    _say "Updated to v${LATEST_VERSION}. Run ./lakeup to bootstrap."
  else
    _say "Update cancelled."
  fi
  exit 0
fi

# ----------------------------
# skill COMMAND
# ----------------------------

if [[ "${1:-}" == "skill" ]]; then
  _install_lake_skill
  exit 0
fi

# ----------------------------
# version COMMAND
# ----------------------------

if [[ "${1:-}" == "version" ]]; then
  _say "lakeup v${LAKE_SETUP_VERSION}"
  if [[ -f "composer.lock" ]]; then
    LARAVEL_VERSION=$(grep -A2 '"name": "laravel/framework"' composer.lock \
      | grep '"version"' | head -1 \
      | sed 's/.*"version": "\([^"]*\)".*/\1/')
    if [[ -n "$LARAVEL_VERSION" ]]; then
      _say "Laravel ${LARAVEL_VERSION}"
    else
      _say "Laravel: installed (version not detected)"
    fi
  elif [[ -f "artisan" ]]; then
    _say "Laravel: installed (no composer.lock found)"
  else
    _say "Laravel: not installed"
  fi
  exit 0
fi

# ----------------------------
# DETECT OS + ARCH
# ----------------------------

_OS="$(uname -s)"
_ARCH="$(uname -m)"

case "$_OS" in
  Linux*)  FRANKEN_OS="linux" ;;
  Darwin*) FRANKEN_OS="mac"   ;;
  *)       _say "Unsupported OS: $_OS"; exit 1 ;;
esac

FRANKEN_ARCH="$_ARCH"
FRANKEN_FILENAME="frankenphp-${FRANKEN_OS}-${FRANKEN_ARCH}"
_say "OS: $FRANKEN_OS  ARCH: $FRANKEN_ARCH  Binary: $FRANKEN_FILENAME"

# ----------------------------
# RESOLVE PATHS
# ----------------------------

if [[ -n "${BASH_SOURCE[0]:-}" && -f "${BASH_SOURCE[0]}" ]]; then
  SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
else
  SCRIPT_DIR="$(pwd)"
fi
TOOLS_DIR="$SCRIPT_DIR/.lake"
FRANKEN_BIN="$TOOLS_DIR/frankenphp"
COMPOSER_BIN="$TOOLS_DIR/composer.phar"
LAKE_INFO_FILE="$TOOLS_DIR/.info"
mkdir -p "$TOOLS_DIR"
cd "$SCRIPT_DIR"

# ----------------------------
# DETECT SETUP MODE
# ----------------------------

LARAVEL_EXISTS=false
LAKE_EXISTS=false
NEEDS_FRANKEN_UPDATE=false
STORED_FRANKEN_VERSION=""
STORED_FRANKEN_OS=""
STORED_FRANKEN_ARCH=""
STORED_LAKE_PORT=""

[[ -f "$SCRIPT_DIR/artisan" ]] && LARAVEL_EXISTS=true
[[ -d "$TOOLS_DIR" ]]          && LAKE_EXISTS=true

if $LAKE_EXISTS && [[ -f "$LAKE_INFO_FILE" ]]; then
  STORED_FRANKEN_VERSION=$(grep "^FRANKEN_VERSION=" "$LAKE_INFO_FILE" 2>/dev/null | cut -d= -f2-)
  STORED_FRANKEN_OS=$(grep     "^FRANKEN_OS="      "$LAKE_INFO_FILE" 2>/dev/null | cut -d= -f2-)
  STORED_FRANKEN_ARCH=$(grep   "^FRANKEN_ARCH="    "$LAKE_INFO_FILE" 2>/dev/null | cut -d= -f2-)
  STORED_LAKE_PORT=$(grep      "^LAKE_PORT="       "$LAKE_INFO_FILE" 2>/dev/null | cut -d= -f2-)
fi

# ----------------------------
# INTRODUCTION
# ----------------------------

if $LARAVEL_EXISTS && ! $LAKE_EXISTS; then
  echo "┌─────────────────────────────────────────────────┐"
  echo "│  Restoring .lake/ for existing project          │"
  echo "├─────────────────────────────────────────────────┤"
  echo "│                                                 │"
